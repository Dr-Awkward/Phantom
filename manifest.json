{
  "manifest_version": 3,
  "name": "Phantom",
  "version": "2.0.0",
  "description": "Protects your privacy by hiding your real searches in decoy traffic and injecting behavioral noise that makes tracking scripts unable to profile you.",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["phantom-inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": [
        "phantom-persona.js",
        "phantom-mouse.js",
        "phantom-scroll.js",
        "phantom-click.js",
        "phantom-hover.js",
        "phantom-keystroke.js",
        "phantom.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["seeds.json", "dashboard.html", "tracker-signatures.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
